# --- Database (Postgres; docker-compose uses the same values) ---
DB_USER=dorm-made
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dorm-made

# --- Auth ---
# JWT signing key. REQUIRED - the app refuses to boot without it.
SECRET_KEY=generate-a-long-random-string

# --- Supabase (storage buckets: profile-pictures, meal-images, event-images) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# --- Stripe ---
STRIPE_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # checkout webhook endpoint
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...  # connect webhook endpoint

# --- Email (Resend) ---
RESEND_API_KEY=re_...

# --- App ---
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=dev                          # dev | prod (prod enables Sentry)
# Comma-separated CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Sentry DSN (only used when ENVIRONMENT=prod)
SENTRY_DSN=
# Run alembic migrations on app startup (disable when deploying >1 instance)
RUN_MIGRATIONS_ON_STARTUP=true
